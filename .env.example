# Groq API key — required for AI extraction. Get one at https://console.groq.com/keys
GROQ_API_KEY=

# Model override (optional). Defaults to llama-3.3-70b-versatile.
GROQ_MODEL=llama-3.3-70b-versatile

# Optional fallback provider. Used only when Groq fails or is rate-limited.
# OCR text is sent to Gemini only when this fallback is invoked.
GEMINI_API_KEY=
# Use a "latest" alias; dated model IDs (e.g. gemini-2.5-flash-lite) are retired for new keys.
GEMINI_MODEL=gemini-flash-lite-latest
